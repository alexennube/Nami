# ─── Nami Configuration ───────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ─── Required ─────────────────────────────────────────────────

# Login credentials for the Nami web UI
NAMI_USERNAME=admin
NAMI_PASSWORD=changeme

# ─── Inference Provider (choose at least one) ────────────────

# OpenRouter API key (get one at https://openrouter.ai/keys)
# Gives access to 400+ models (GPT-4, Claude, Gemini, Llama, etc.)
OPENROUTER_API_KEY=

# LM Studio local inference (no key needed)
# Start LM Studio, load a model, enable the local server
# Default URL is http://localhost:1234/v1 — change if different
# When running in Docker, use http://host.docker.internal:1234/v1
LM_STUDIO_BASE_URL=http://host.docker.internal:1234/v1

# ─── Optional: Google Gemini (OAuth2) ────────────────────────

# Google Cloud OAuth2 credentials for Gemini inference
# Create at https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ─── Optional: X (Twitter) Integration ───────────────────────

# X API credentials for social media tools
# X_API_KEY=
# X_API_SECRET=
# X_ACCESS_TOKEN=
# X_ACCESS_TOKEN_SECRET=

# ─── Optional: Web Search ────────────────────────────────────

# Perplexity API key for the web_search tool
# PERPLEXITY_API_KEY=

# ─── Database (auto-configured by docker-compose) ────────────
# Only set this if running WITHOUT docker-compose
# DATABASE_URL=postgresql://nami:nami@localhost:5432/nami

# ─── Server ──────────────────────────────────────────────────
# PORT=5000
